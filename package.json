{
  "name": "agent-snap",
  "version": "0.5.3",
  "description": "Framework-agnostic DOM snapshot for coding agents",
  "homepage": "https://github.com/vampaz/agent-snap#readme",
  "bugs": {
    "url": "https://github.com/vampaz/agent-snap/issues"
  },
  "license": "MIT",
  "author": "Carlos Rodrigues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vampaz/agent-snap.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:ext": "node scripts/write-extension-config.mjs && npm run build && rm -rf extension/dist && cp -R dist extension/dist",
    "build:ext:env": "node scripts/build-extension-from-env.mjs",
    "package:ext": "node scripts/sync-extension-version.mjs && npm run build:ext && cd extension && zip -r ../agent-snap-extension-v$npm_package_version.zip . -x '*.git*' -x '*.DS_Store*'",
    "generate:assets": "npx tsx scripts/generate-assets.ts",
    "generate:demo": "npx tsx scripts/generate-demo.ts",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "format": "oxfmt",
    "format:fix": "oxfmt",
    "watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "npm run build:ext && playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@zumer/snapdom": "^2.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
